install.packages("qtl2convert")
library(qtl2)
library(qtl2convert)

# STEP 1: Load dataset using your JSON control file
cross <- read_cross2("D:\\control\\cm.mbp.ss.100k.sites.json")  # Replace with your actual file name

# STEP 2: Calculate genotype probabilities
pr <- calc_genoprob(cross, error_prob = 0.002)

# STEP 3: Compute kinship matrix (optional but recommended)
kinship <- calc_kinship(pr, "loco")

# STEP 4: Run the genome scan
scan1_output <- scan1(pr, cross$pheno, kinship = kinship)

# STEP 5: Find peaks above the LOD threshold = 0.5
peaks <- find_peaks(scan1_output, cross$gmap, threshold = 0.5)
print(peaks)
head(scan1_output)


